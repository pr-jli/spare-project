# Product Hunt API — https://www.producthunt.com/v2/oauth/applications
PH_API_URL=https://api.producthunt.com/v2/api/graphql
PH_API_TOKEN=your_developer_token_here

# OAuth app credentials (login setup only)
PH_API_CLIENT_ID=your_client_id
PH_API_CLIENT_SECRET=your_client_secret
PH_OAUTH_REDIRECT_URI=https://www.producthunt.com/@your_username

# E2E
BASE_URL=https://www.producthunt.com
E2E_AUTH_STORAGE=tests/e2e/.auth/user.json

# Test data
SAMPLE_USERNAME=rrhoover
SAMPLE_VIEWER_USERNAME=pranjali_katiyar
